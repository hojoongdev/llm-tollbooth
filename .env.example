# Copy to .env and edit as needed:  cp .env.example .env
#
# Every value below has a working default, so P1–P2 run with an empty .env — no
# secrets required. Uncomment only what you want to change.

# --- Host ports (change only if they clash with something local) ---
# KAFKA_EXTERNAL_PORT=9092
# CASSANDRA_PORT=9042
# MONGO_PORT=27017
# DASHBOARD_PORT=3000
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025

# --- Console login (optional) ---
# Default: open console, no login. To require a login, set AUTH_MODE=single and
# fill in the three values below — that's it, no code changes.
AUTH_MODE=none
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me
# SESSION_SECRET=            # random secret; generate with:  openssl rand -hex 32
# COOKIE_SECURE=true         # set only when serving the console over HTTPS

# --- Coming in later phases ---
# P3 gateway — real provider keys (a built-in mock provider works without them):
#   OPENAI_API_KEY=
#   ANTHROPIC_API_KEY=
# P4 email alerts — defaults already point at the bundled Mailpit:
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
