# Copy to .env and edit as needed:  cp .env.example .env
#
# Every value below has a working default, so the whole stack runs with an empty
# .env — no secrets required, and the built-in mock provider means no LLM
# account either. Uncomment only what you want to change.

# --- Host ports (change only if they clash with something local) ---
# GATEWAY_PORT=8080
# DASHBOARD_PORT=3000
# KAFKA_EXTERNAL_PORT=9092
# CASSANDRA_PORT=9042
# MONGO_PORT=27017
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025

# --- Console login (optional) ---
# Default: open console, no login. To require a login, set AUTH_MODE=single and
# fill in the three values below — that's it, no code changes.
AUTH_MODE=none
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me
# SESSION_SECRET=            # random secret; generate with:  openssl rand -hex 32
# COOKIE_SECURE=true         # set only when serving the console over HTTPS

# --- Gateway ---
# Calls to the gateway ALWAYS need an API key, whatever AUTH_MODE says — that
# setting is only about console logins. With AUTH_MODE=none there is no console
# login to issue a key from, so the gateway mints one at boot and prints it:
#   docker compose logs gateway | grep 'demo API key'
# Only its hash is stored, so an unpinned key is regenerated on every restart.
# Set this to pin one instead (local demos only — issue real keys from the
# console for anything exposed):
# GATEWAY_DEFAULT_KEY=tb_local_dev_key

# Mock provider — the fake LLM that lets the stack run with no real account.
# MOCK_LATENCY_MS=250        # 0 = no fake wait; use it to measure the gateway's own overhead
# MOCK_ERROR_RATE=0          # 0..1, injects upstream failures so the error path is visible
# LOG_LEVEL=info             # warn quiets per-request logs during load tests

# Response cache. Off by default: caching changes what a call means (ask twice at
# temperature 1 and you're meant to get two answers), so it's your call, not ours.
# CACHE_TTL_SECONDS=300

# --- Real providers ---
# Add a key and that provider's models stop being served by the mock — no other
# change. Which provider owns which model comes from the pricing table, editable
# in the console, so a model you add there routes itself.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
#
# Any OpenAI-compatible server you run yourself (vLLM, Ollama, LM Studio). The
# URL alone switches it on — most of them want no key. Use host.docker.internal
# to reach a server running on your own machine.
# SELFHOST_BASE_URL=http://host.docker.internal:8000/v1
# SELFHOST_API_KEY=
#
# Point these at a proxy or a compatible vendor if you don't use the real thing.
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# PROVIDER_TIMEOUT_MS=60000

# --- Coming in later phases ---
# P4 email alerts — defaults already point at the bundled Mailpit:
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
