# Copy to .env and fill in as needed:  cp .env.example .env
#
# This file grows one phase at a time. Everything below has a working default,
# so P1 runs with an empty .env — no secrets required (the gateway uses a mock
# provider until you add real keys).

# --- Infra (host-side ports; change only if they clash with something local) ---
KAFKA_EXTERNAL_PORT=9092
CASSANDRA_PORT=9042
MONGO_PORT=27017
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# --- Coming in later phases (left here so you know what's next) ---
# P3 gateway:
#   OPENAI_API_KEY=
#   ANTHROPIC_API_KEY=
# P3+ console auth (none | single | multi):
#   AUTH_MODE=none
#   ADMIN_EMAIL=
#   ADMIN_PASSWORD=
# P4 email alert action (defaults point at the bundled Mailpit):
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
