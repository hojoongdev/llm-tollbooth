# Copy to .env and edit as needed:  cp .env.example .env
#
# Every value below has a working default, so the whole stack runs with an empty
# .env — no secrets required, and the built-in mock provider means no LLM
# account either. Uncomment only what you want to change.

# --- Host ports (change only if they clash with something local) ---
# GATEWAY_PORT=8080
# DASHBOARD_PORT=3000
# KAFKA_EXTERNAL_PORT=9092
# CASSANDRA_PORT=9042
# MONGO_PORT=27017
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025

# --- Console login (optional) ---
# Default: open console, no login. To require a login, set AUTH_MODE=single and
# fill in the three values below — that's it, no code changes.
AUTH_MODE=none
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me
# SESSION_SECRET=            # random secret; generate with:  openssl rand -hex 32
# COOKIE_SECURE=true         # set only when serving the console over HTTPS

# --- Gateway ---
# Calls to the gateway ALWAYS need an API key, whatever AUTH_MODE says — that
# setting is only about console logins. With AUTH_MODE=none there is no console
# login to issue a key from, so the gateway mints one at boot and prints it:
#   docker compose logs gateway | grep 'demo API key'
# Only its hash is stored, so an unpinned key is regenerated on every restart.
# Set this to pin one instead (local demos only — issue real keys from the
# console for anything exposed):
# GATEWAY_DEFAULT_KEY=tb_local_dev_key

# Mock provider — the fake LLM that lets the stack run with no real account.
# MOCK_LATENCY_MS=250        # 0 = no fake wait; use it to measure the gateway's own overhead
# MOCK_ERROR_RATE=0          # 0..1, injects upstream failures so the error path is visible
# LOG_LEVEL=info             # warn quiets per-request logs during load tests

# Response cache. Off by default: caching changes what a call means (ask twice at
# temperature 1 and you're meant to get two answers), so it's your call, not ours.
# CACHE_TTL_SECONDS=300

# --- Real providers ---
# Add a key and that provider's models stop being served by the mock — no other
# change. Which provider owns which model comes from the pricing table, editable
# in the console, so a model you add there routes itself.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
#
# Any OpenAI-compatible server you run yourself (vLLM, Ollama, LM Studio). The
# URL alone switches it on — most of them want no key. Use host.docker.internal
# to reach a server running on your own machine.
# SELFHOST_BASE_URL=http://host.docker.internal:8000/v1
# SELFHOST_API_KEY=
#
# Point these at a proxy or a compatible vendor if you don't use the real thing.
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# PROVIDER_TIMEOUT_MS=60000
#
# Model fallback (P5). When a call's provider errors or times out, retry it on this
# model instead of handing the caller the failure. Because routing comes from the
# pricing table, the backup can be a different provider entirely — gpt-4o falling back
# to claude-haiku is just this line. A key can name its own backup in the console,
# which wins over this. A malformed request is never retried: a different model won't
# fix it.
# GATEWAY_FALLBACK_MODEL=gpt-4o-mini

# --- Alert rules (P4) ---
# Email alerts already work: the rules worker sends to the bundled Mailpit, which
# catches everything and shows it at http://localhost:8025. No account, no
# credentials, and no way to accidentally mail a real person while you're testing a
# threshold. Point these at a real relay when you want the alerts to leave the box —
# setting SMTP_USER is also what turns on STARTTLS.
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_FROM=alerts@tollbooth.local
# SMTP_USER=
# SMTP_PASSWORD=
#
# How often the rules worker re-checks its rules against the rollup. Rules are
# windowed in hours, so there is little point going much below this.
# RULES_EVAL_SECONDS=20
#
# How many request documents one `tag` action will label. A rule scoped to `all` over
# a long window could otherwise match every document in it.
# RULES_TAG_LIMIT=5000
#
# What fraction of matching calls a `keyword` rule actually opens and reads. It defaults
# to all of them, which is the opposite of what "sampling based" usually implies — and
# on purpose. Sampling is here to bound cost: a keyword rule is the one condition that
# needs a Mongo read per request, because the text it searches is in neither the rollup
# nor the event. But what people watch keywords for is a secret leaking, and a rule that
# samples 10% of a leak misses it nine times out of ten while looking like it works. So
# turning this down is a decision you make on purpose, knowing that trade.
# RULES_KEYWORD_SAMPLE_RATE=1.0
#
# Shared secret the console and the rules worker use to tell the gateway "a key you
# have cached just changed" — without it a block takes up to 30s to bite, because the
# gateway caches key state for that long. It is not a credential to anything: the one
# route it guards flushes a cache and reads nothing back. Change it if you expose the
# gateway's port; leave it unset and the route is simply not registered.
# GATEWAY_INTERNAL_TOKEN=local-dev-internal

# --- Quality evaluation (P5) ---
# The eval worker samples calls and asks a judge LLM to score them 1..5 on relevance,
# hallucination risk and tone. These values only *seed* the settings — once the stack
# has run, the console's Settings screen owns them, and a change there takes effect in
# seconds without a restart.
#
# Whole-corpus evaluation costs one judge call per request, which is why it samples.
# EVAL_SAMPLE_RATE=0.1
#
# The judge. The worker calls the gateway like any other client, so with no provider key
# this is answered by the mock — which returns prose, not a rubric, so the worker falls
# back to a deterministic stand-in score derived from the answer's text. That is enough
# to demo quality trends and trip a quality-drop rule, and it is not a real quality
# signal. Add a provider key above and this becomes a genuine evaluation, for real money
# (a low-cost model is the point).
# EVAL_MODEL=gpt-4o-mini
#
# Evaluate only some models / only some keys. Empty = all of them.
# EVAL_MODELS=gpt-4o,claude-3-5-sonnet
# EVAL_KEYS=key_abc
#
# The worker's own API key, provisioned in Mongo at boot. Its judge calls are tagged and
# attributed to this key, and never sampled — otherwise evaluation would evaluate itself.
# EVAL_API_KEY=tb_eval_worker_key
